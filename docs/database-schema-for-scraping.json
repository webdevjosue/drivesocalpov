          "example": "(619) 239-0512",
          "required": false,
          "scraping_priority": "low"
        },
        {
          "name": "address",
          "type": "text",
          "description": "Street address",
          "example": "1549 El Prado, San Diego, CA 92101",
          "required": false,
          "scraping_priority": "high"
        },
        {
          "name": "city",
          "type": "text",
