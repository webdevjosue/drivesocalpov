          "required": false,
          "scraping_priority": "medium",
          "range": {"min": 1, "max": 4}
        },
        {
          "name": "is_free",
          "type": "boolean",
          "description": "Whether the location is completely free",
          "example": true,
          "required": false,
          "scraping_priority": "high"
        },
        {
          "name": "cost_estimate",
          "type": "text",
