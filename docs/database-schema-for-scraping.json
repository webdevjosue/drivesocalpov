        {
          "name": "review_count",
          "type": "integer",
          "description": "Number of reviews",
          "example": 15420,
          "required": false,
          "scraping_priority": "low"
        },
        {
          "name": "photos",
          "type": "array",
          "description": "Array of photo URLs",
